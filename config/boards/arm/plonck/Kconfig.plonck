config BOARD_PLONCK
	select SOC_NRF52840_QIAA
	select ZMK_BOARD_COMPAT if BOARD_PLONCK_NRF52840_ZMK
	imply RETAINED_MEM if BOARD_PLONCK_NRF52840_ZMK
	imply RETENTION if BOARD_PLONCK_NRF52840_ZMK
	imply RETENTION_BOOT_MODE if BOARD_PLONCK_NRF52840_ZMK
